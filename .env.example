# ------------------------------------------------------------
# BlackRidge Platforms - environment variables
# Copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# Database (Postgres - Neon, Supabase, RDS, local, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Admin bootstrap
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# AI
ANTHROPIC_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# AWS S3 (object storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=

# Object storage paths (were Replit Object Storage - set to local/S3 paths)
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# OIDC / auth issuer
ISSUER_URL=

# ------------------------------------------------------------
# The following were injected by Replit. Not needed outside Replit
# unless you still rely on Replit integrations:
# REPL_ID, REPL_IDENTITY, REPLIT_DOMAINS, REPLIT_DEV_DOMAIN,
# REPLIT_DEPLOYMENT_URL, REPLIT_CONNECTORS_HOSTNAME, WEB_REPL_RENEWAL
# ------------------------------------------------------------
