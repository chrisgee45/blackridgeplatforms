# ------------------------------------------------------------
# BlackRidge Platforms - environment variables
# Copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# Database (Postgres - Neon, Supabase, RDS, local, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Admin bootstrap
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key (pk_test_... / pk_live_...) - exposed to the browser by Vite
VITE_STRIPE_PUBLISHABLE_KEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# AI
ANTHROPIC_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ElevenLabs
ELEVENLABS_API_KEY=
# Ridge's voice id
ELEVENLABS_VOICE_ID=
# Jake's voice id — separate so he sounds like a different person.
# Falls back to ELEVENLABS_VOICE_ID if unset.
ELEVENLABS_JAKE_VOICE_ID=
# Travis's voice id (outreach agent). Falls back to ELEVENLABS_JAKE_VOICE_ID,
# then ELEVENLABS_VOICE_ID, if unset.
ELEVENLABS_TRAVIS_VOICE_ID=

# Calendar-event reminders. Two channels - the email gateway is preferred
# if set, otherwise Twilio is used.
#
# Carrier email-to-SMS gateway (no Twilio needed, avoids A2P 10DLC filtering).
# Format: <10-digit-number>@<carrier-domain>, e.g. 4055551234@vtext.com
REMINDER_SMS_EMAIL=
#
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Cell number that Twilio reminders are texted to (E.164, e.g. +14055551234)
REMINDER_PHONE=

# Web push notifications (browser/phone alerts for calendar reminders).
# Generate a pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# AWS S3 (object storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=
# Optional override — bucket for app documents (generated PDFs, uploads,
# screenshots). Defaults to AWS_S3_BUCKET when unset. Different prefixes
# inside the bucket keep backups/ and the document tree separated.
AWS_S3_DOCUMENTS_BUCKET=

# Object storage paths (were Replit Object Storage - set to local/S3 paths)
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# OIDC / auth issuer
ISSUER_URL=

# ------------------------------------------------------------
# The following were injected by Replit. Not needed outside Replit
# unless you still rely on Replit integrations:
# REPL_ID, REPL_IDENTITY, REPLIT_DOMAINS, REPLIT_DEV_DOMAIN,
# REPLIT_DEPLOYMENT_URL, REPLIT_CONNECTORS_HOSTNAME, WEB_REPL_RENEWAL
# ------------------------------------------------------------
